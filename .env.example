# Окружеине
NODE_ENV=local | production
PORT=5000
SALT=password_salt

DB_HOST=db
DB_PORT=5432

# postgresql
PG_USER=admin
PG_PASSWORD=strong_password
PG_DATABASE=nestjs_test_task_db

# pg_admin только для разработки
PG_ADMIN_EMAIL=admin@example.com
PG_ADMIN_PASSWORD=admin_pg_db_password
PG_ADMIN_PORT=7777

# Redis
REDIS_PASSWORD=hello_redis
REDIS_PORT=6379
REDIS_USER=default
REDIS_HOST=localhost
REDIS_TTL=2h

# JWT
APPLICATION_JWT_SECRET=my_secret
APPLICATION_JWT_EXPIRES_IN=1d
APPLICATION_JWT_REFRESH_SECRET=my_refresh_secret
APPLICATION_JWT_REFRESH_EXPIRES_IN=3d
